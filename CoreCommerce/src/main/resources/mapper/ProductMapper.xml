<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.CoreCommerce.repository.ProductRepository">
	
	<resultMap id="ProductMap" type="com.CoreCommerce.domain.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="imageUrl" column="image_url"/>
    </resultMap>
	
	
     <!-- 전체 상품 조회 -->
    <select id="findAll" resultMap="ProductMap">
        SELECT *
        FROM product
        ORDER BY id DESC
    </select>
    
    <select id="findAllCount" resultType="int">
        SELECT COUNT(*) FROM product
    </select>
    
    <select id="search" resultMap="ProductMap">

		SELECT *
		FROM product
		WHERE 1=1
		
		<if test="keyword != null and keyword != ''">
		    AND name LIKE CONCAT('%', #{keyword}, '%')
		</if>
		<if test="minPrice != null">
		    AND price &gt;= #{minPrice}
		</if>
		<if test="maxPrice != null">
		    AND price &lt;= #{maxPrice}
		</if>
		<choose>
		    <when test="sort == 'price_low'">
		        ORDER BY price ASC
		    </when>
		    <when test="sort == 'price_high'">
		        ORDER BY price DESC
		    </when>
		    <otherwise>
		        ORDER BY created_at DESC
		    </otherwise>
		</choose>
	</select>
    
    <select id="findOfferProductList" resultMap="ProductMap">
    	 SELECT *
	     FROM product
	     WHERE offerYn =  1
         ORDER BY id DESC
         LIMIT 4
    </select>

    <!-- ID로 단일 상품 조회 -->
    <select id="findById" parameterType="long" resultMap="ProductMap">
        SELECT *
        FROM product
        WHERE id = #{id}
    </select>

    <!-- 상품 등록 -->
    <insert id="insert" parameterType="com.CoreCommerce.domain.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (name, description, price, stock, image_url)
        VALUES (#{name}, #{description}, #{price}, #{stock}, #{imageUrl})
    </insert>

    <!-- 상품 수정 -->
    <update id="update" parameterType="com.CoreCommerce.domain.Product">
        UPDATE product
        SET
            name = #{name},
            description = #{description},
            price = #{price},
            stock = #{stock},
            image_url = #{imageUrl},
            offerYn = #{offerYn}
        WHERE id = #{id}
    </update>

    <!-- 상품 삭제 -->
    <delete id="delete" parameterType="long">
        DELETE FROM product
        WHERE id = #{id}
    </delete>
    
    <select id="findMainPage" resultMap="ProductMap">
    	select * from product order by created_at desc limit 8
    </select>
    
    <!-- 🔥 재고 차감 -->
	<update id="decreaseStock">
	    UPDATE product
	    SET stock = stock - #{quantity}
	    WHERE id = #{productId}
	      AND stock >= #{quantity}
	</update>
	
	<update id="increaseStock">
	    UPDATE product
	    SET stock = stock + #{quantity}
	    WHERE id = #{productId}
	</update>
	
	<select id="findPaging" resultMap="ProductMap">

		SELECT *
		FROM product
		ORDER BY created_at DESC
		LIMIT #{limit} OFFSET #{offset}
		
	</select>



</mapper>